# HuggingFace API token (write access for dataset uploads)
HF_TOKEN=hf_your_token_here

# HuggingFace dataset repository
REPO_ID=knl2366/NREL_Sky_Imagery

# Local data root (Jetstream2 volume or local path)
LOCAL_ROOT=/media/volume/Primary-Dataset

# Jetstream2 VM credentials (for deployment)
HOSTNAME=your-instance.projects.jetstream-cloud.org
PUBLICIP=0.0.0.0
USER=exouser
PASSPHRASE="your passphrase here"
