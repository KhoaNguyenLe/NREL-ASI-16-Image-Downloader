#!/bin/bash
# Pre-commit hook: sync .env.example with .env keys
# Warns if .env has keys not present in .env.example

ENV_FILE=".env"
EXAMPLE_FILE=".env.example"

if [ ! -f "$ENV_FILE" ]; then
    exit 0
fi

if [ ! -f "$EXAMPLE_FILE" ]; then
    echo "WARNING: .env exists but .env.example is missing."
    echo "Create .env.example with placeholder values for all keys."
    exit 1
fi

# Extract variable names (lines with = that aren't comments)
ENV_KEYS=$(grep -v '^\s*#' "$ENV_FILE" | grep '=' | cut -d'=' -f1 | sort)
EXAMPLE_KEYS=$(grep -v '^\s*#' "$EXAMPLE_FILE" | grep '=' | cut -d'=' -f1 | sort)

MISSING=""
for key in $ENV_KEYS; do
    if ! echo "$EXAMPLE_KEYS" | grep -qx "$key"; then
        MISSING="$MISSING  $key\n"
    fi
done

if [ -n "$MISSING" ]; then
    echo "WARNING: .env has keys not in .env.example:"
    echo -e "$MISSING"
    echo "Please update .env.example with placeholder values for these keys."
    echo "(Commit proceeds, but collaborators won't know about these variables.)"
fi

exit 0
